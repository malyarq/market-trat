{
  "manifest_version": 3,
  "name": "MarketTrat",
  "version": "0.7.0",
  "description": "Собирает расходы из чеков Ozon, Wildberries и Яндекс Маркета, учитывает возвраты и экспортирует CSV.",
  "permissions": [
    "activeTab",
    "cookies",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.ozon.ru/*",
    "https://ozon.ru/*",
    "https://www.wildberries.ru/*",
    "https://wildberries.ru/*",
    "https://astro.wildberries.ru/*",
    "https://receipt.wb.ru/*",
    "https://market.yandex.ru/*",
    "https://check.yandex.ru/*",
    "https://api.github.com/*"
  ],
  "action": {
    "default_title": "MarketTrat"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "vendor/pdf.mjs",
        "vendor/pdf.worker.mjs"
      ],
      "matches": [
        "https://www.ozon.ru/*",
        "https://ozon.ru/*"
      ]
    }
  ]
}
